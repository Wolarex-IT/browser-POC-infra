# Host docker group GID. Lets non-root appuser in the worker container reach the
# mounted /var/run/docker.sock to spawn browser containers. Find it with:
#   getent group docker
DOCKER_GID=999

# Docker network name the worker and the spawned CloakBrowser containers share.
# The worker reaches each browser by container-name DNS over this network.
BROWSER_NETWORK=cloak_net

# Host + container port the FastAPI app (gunicorn) listens on. Changing it needs
# a rebuild - the bind is baked into the image CMD.
APP_PORT=8000

# Postgres credentials + database (used by the postgres service and by the
# DATABASE_URL / SYNC_DATABASE_URL the app and worker connect with).
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_DB=browser_poc

# RabbitMQ credentials (Celery broker). Used by the rabbitmq service and the
# CELERY_BROKER_URL.
RABBITMQ_USER=guest
RABBITMQ_PASS=change-me

# The following connection strings are NOT set here - docker-compose builds them
# from the credentials above (see the x-app-env anchor) so secrets live in one
# place only. Set them by hand ONLY when running the app or worker outside compose:
#   DATABASE_URL=postgresql+asyncpg://<user>:<pass>@<host>:5432/<db>
#   SYNC_DATABASE_URL=postgresql+psycopg://<user>:<pass>@<host>:5432/<db>
#   CELERY_BROKER_URL=amqp://<user>:<pass>@<host>:5672//
